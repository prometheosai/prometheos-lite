      "node_type": "placeholder",
      "config": {
        "retries": 1,
        "retry_delay_ms": 500
      }
    },
    {
      "id": "phase3",
      "node_type": "placeholder",
      "config": {
        "retries": 1,
        "retry_delay_ms": 500
      }
    },
    {
      "id": "phase4",
      "node_type": "placeholder",
      "config": {
        "retries": 1,
        "retry_delay_ms": 500
      }
    },
    {
      "id": "phase5",
      "node_type": "placeholder",
      "config": {
        "retries": 1,
        "retry_delay_ms": 500
